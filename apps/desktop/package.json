{
  "name": "@kb-vault/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node -e \"console.log('Run from renderer with npm run dev:renderer and main with npm run dev:main')\"",
    "dev:renderer": "vite",
    "dev:main": "electron dist/main/main.js",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "build": "pnpm -C ../../packages/shared-types build && tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && tsc -p tsconfig.renderer.json && vite build",
    "build:main": "pnpm -C ../../packages/shared-types build && tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "typecheck": "tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json",
    "test": "playwright test --config=playwright.config.ts",
    "test:smoke": "playwright test --config=playwright.config.ts --grep @smoke"
  },
  "dependencies": {
    "@kb-vault/db": "workspace:*",
    "@kb-vault/shared-types": "workspace:*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^30.0.0",
    "playwright": "^1.47.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
