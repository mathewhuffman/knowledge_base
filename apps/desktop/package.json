{
  "name": "@kb-vault/desktop",
  "version": "0.2.6",
  "private": true,
  "description": "Local-first Electron desktop application for automating Zendesk KB maintenance from bulk PBI uploads.",
  "main": "dist/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:renderer": "vite",
    "dev:main": "pnpm run rebuild:native && pnpm run build:main && electron dist/main/main.js",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "build": "pnpm -C ../../packages/shared-types build && pnpm -C ../../packages/diff-engine build && tsc -p tsconfig.main.json && node ./scripts/sync-main-dist.mjs && tsc -p tsconfig.preload.json && tsc -p tsconfig.renderer.json && vite build",
    "build:main": "pnpm -C ../../packages/shared-types build && pnpm -C ../../packages/db build && pnpm -C ../../packages/mcp-server build && pnpm -C ../../packages/agent-runtime build && pnpm -C ../../packages/zendesk-client build && pnpm -C ../../packages/diff-engine build && tsc -p tsconfig.main.json && node ./scripts/sync-main-dist.mjs && tsc -p tsconfig.preload.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "dist:mac": "pnpm run build && electron-builder --mac dmg zip",
    "dist:mac:unsafe": "pnpm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip -c.mac.identity=- -c.mac.notarize=false",
    "dist:win": "pnpm run build && electron-builder --win nsis",
    "publish:mac": "pnpm run build && electron-builder --mac dmg zip --publish always",
    "publish:win": "pnpm run build && electron-builder --win nsis --publish always",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "playwright test --config=playwright.config.ts",
    "test:smoke": "playwright test --config=playwright.config.ts --grep @smoke"
  },
  "build": {
    "appId": "com.kbvault.desktop",
    "productName": "KnowledgeBase",
    "artifactName": "KnowledgeBase-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "electronUpdaterCompatibility": ">=2.16",
    "publish": [
      {
        "provider": "github",
        "owner": "mathewhuffman",
        "repo": "knowledge_base",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "forceCodeSigning": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.6",
    "@fontsource/roboto": "^5.2.10",
    "@kb-vault/agent-runtime": "workspace:^",
    "@kb-vault/db": "workspace:*",
    "@kb-vault/diff-engine": "workspace:*",
    "@kb-vault/mcp-server": "workspace:*",
    "@kb-vault/shared-types": "workspace:*",
    "@kb-vault/zendesk-client": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "@tiptap/core": "^3.20.5",
    "@tiptap/extension-color": "^3.20.5",
    "@tiptap/extension-font-family": "^3.20.5",
    "@tiptap/extension-highlight": "^3.20.5",
    "@tiptap/extension-link": "^3.20.5",
    "@tiptap/extension-text-align": "^3.20.5",
    "@tiptap/extension-text-style": "^3.20.5",
    "@tiptap/extension-underline": "^3.20.5",
    "@tiptap/pm": "^3.20.5",
    "@tiptap/react": "^3.20.5",
    "@tiptap/starter-kit": "^3.20.5",
    "electron-updater": "^6.8.3",
    "monaco-editor": "^0.55.1",
    "quill": "^2.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.47.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
